# Copy this file to .env and fill in the values
# NOTE: Use single quotes if your value contains special characters: PASSWORD='p@ss!'

# ----------------------------
# Backend
# ----------------------------

SPRING_PROFILES_ACTIVE=prod

# DB credentials
# URL must use the TCPS descriptor form so Oracle JDBC applies the wallet for SSL trust.
# Using @//host:port/service bypasses the wallet and causes PKIX certificate errors.
SPRING_DATASOURCE_URL='jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCPS)(HOST=hostname)(PORT=port))(CONNECT_DATA=(SERVICE_NAME=YOUR_SERVICE_NAME)))'
SPRING_DATASOURCE_USERNAME=''
SPRING_DATASOURCE_PASSWORD=''

# Jasper server — REQUIRED with the prod profile (no defaults in application.yml).
# Get the URLs from the team; they are intentionally not committed to the repo.
JASPER_SERVER_LOGIN_URL=''
JASPER_SERVER_FETCH_URL=''
JASPER_SERVER_PUT_URL=''
JASPER_SERVER_REPORT_URI_BASE=''
JASPER_SERVER_USERNAME=''
JASPER_SERVER_PASSWORD=''

# Backend JWT validation — REQUIRED with the prod profile; must point at the
# same Cognito User Pool the frontend uses.
# JWT_JWKS_URI=https://cognito-idp.ca-central-1.amazonaws.com/{COGNITO_USER_POOL_ID}/.well-known/jwks.json
# JWT_ISSUER=https://cognito-idp.ca-central-1.amazonaws.com/{COGNITO_USER_POOL_ID}
# JWT_AUDIENCE={COGNITO_USER_POOL_CLIENT_ID}
JWT_JWKS_URI=''
JWT_ISSUER=''
JWT_AUDIENCE=''

JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# Backend mock auth — pairs with "mockUser": true in frontend/public/amplify-config.js.
# Required for local dev with the prod profile (which hardcodes mock auth off);
# without it every API call is rejected with 401. Set to false to use real Cognito auth.
AUTH_MOCK_ENABLED=true
AUTH_MOCK_ROLES=ADMIN

# ----------------------------
# Frontend
# ----------------------------
# The frontend takes NO build-time env vars. All environment-specific config is
# injected at runtime via amplify-config.js (window.amplifyConfig):
#   - locally: edit frontend/public/amplify-config.js
#   - OpenShift: the ConfigMap in frontend/openshift.deploy.yml
#
# Keys: appEnv, idpName, region, userPoolId, userPoolClientId, cognitoDomain,
#       oauthScopes, redirectSignIn, redirectSignOut, mockUser, famClientId
#
# mockUser: true bypasses Cognito/FAM login — only honoured on localhost.
# famClientId determines the Cognito group prefix; CSP roles map to groups:
#   CSP_VIEWER, CSP_SUBMITTER, CSP_APPROVER, CSP_ADMIN
#
# Cognito values (User Pool ID, client ID, domain, IDP name) come from the
# FAM team / DevOps. Redirect URLs must match the FAM application registration;
# redirectSignOut must be the full IDIR logout chain URL for your environment.
