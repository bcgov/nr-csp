# Copy this file to .env and fill in the values
# NOTE: Use single quotes if your value contains special characters: PASSWORD='p@ss!'

# ----------------------------
# Backend
# ----------------------------

SPRING_PROFILES_ACTIVE=prod

# DB credentials
# URL must use the TCPS descriptor form so Oracle JDBC applies the wallet for SSL trust.
# Using @//host:port/service bypasses the wallet and causes PKIX certificate errors.
SPRING_DATASOURCE_URL='jdbc:oracle:thin:@(DESCRIPTION=(ADDRESS=(PROTOCOL=TCPS)(HOST=hostname)(PORT=port))(CONNECT_DATA=(SERVICE_NAME=YOUR_SERVICE_NAME)))'
SPRING_DATASOURCE_USERNAME=''
SPRING_DATASOURCE_PASSWORD=''

# Jasper server credentials
JASPER_SERVER_USERNAME=''
JASPER_SERVER_PASSWORD=''

JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# ----------------------------
# Frontend
# ----------------------------

# Set to true to bypass Cognito/FAM login in local development.
# Set to false and fill in the real auth vars below to use FAM.
VITE_MOCK_USER=true

# ----------------------------
# FAM / Cognito (required when VITE_MOCK_USER=false)
# ----------------------------
# Also set AUTH_MOCK_ENABLED=false in the backend when using real auth.

# AUTH_MOCK_ENABLED=false
# AUTH_MOCK_ROLES=ADMIN

# Cognito User Pool (from FAM team / DevOps)
# COGNITO_USER_POOL_ID=ca-central-1_XXXXXXXXX
# COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
# COGNITO_DOMAIN=nrs-XXXX.auth.ca-central-1.amazoncognito.com

# OAuth scopes — comma-separated, no spaces
# COGNITO_OAUTH_SCOPES=openid,profile,email

# Cognito identity provider name registered in FAM (e.g. DEV-IDIR, TEST-IDIR, PROD-IDIR)
# COGNITO_IDP_NAME=DEV-IDIR

# Redirect URLs must match the values registered in the FAM application.
# redirectSignOut must be the full IDIR logout chain URL for your environment.
# COGNITO_REDIRECT_SIGN_IN=http://localhost:3000
# COGNITO_REDIRECT_SIGN_OUT=https://logontest7.gov.bc.ca/clp-cgi/logoff.cgi?retnow=1&returl=https://dev.loginproxy.gov.bc.ca/auth/realms/standard/protocol/openid-connect/logout?redirect_uri=http://localhost:3000/logout

# Backend JWT validation — must point at the same User Pool as above
# JWT_JWKS_URI=https://cognito-idp.ca-central-1.amazonaws.com/{COGNITO_USER_POOL_ID}/.well-known/jwks.json
# JWT_ISSUER=https://cognito-idp.ca-central-1.amazonaws.com/{COGNITO_USER_POOL_ID}
# JWT_AUDIENCE={COGNITO_USER_POOL_CLIENT_ID}

# FAM application client ID — determines the Cognito group prefix.
# CSP roles map to groups: CSP_VIEWER, CSP_SUBMITTER, CSP_APPROVER, CSP_ADMIN
# VITE_FAM_CLIENT_ID=CSP
