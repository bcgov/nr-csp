{
  "name": "nr-csp-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "cross-env CI=false vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,json}\"",
    "test": "vitest",
    "test:unit": "vitest --project node",
    "test:browser": "cross-env VITEST_BROWSER_ENABLED=true vitest --project browser",
    "test:coverage": "vitest run --coverage --project node",
    "test:ci": "vitest run --ci"
  },
  "dependencies": {
    "@bcgov-nr/nr-theme": "^1.8.9",
    "@carbon/icons-react": "^11.64.0",
    "@carbon/pictograms-react": "^11.83.0",
    "@carbon/react": "^1.104.1",
    "@tanstack/react-query": "^5.84.1",
    "aws-amplify": "^6.16.2",
    "axios": "^1.13.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tanstack/eslint-plugin-query": "^5.84.2",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "happy-dom": "^20.0.0",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.0.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "vitest-browser-react": "^1.0.1"
  }
}
