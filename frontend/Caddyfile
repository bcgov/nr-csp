{
	# Runtime log verbosity; driven by the LOG_LEVEL env var set in
	# openshift.deploy.yml (DEBUG, INFO, WARN, ERROR). Defaults to INFO.
	log {
		level {$LOG_LEVEL:INFO}
	}
}

:3000 {
	encode zstd gzip

	handle /health {
		respond 200
	}

	handle /api/* {
		reverse_proxy {$BACKEND_URL}
	}

	handle {
		root * /usr/share/caddy
		try_files {path} /index.html
		file_server
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		# TLS terminates at the OpenShift edge router, so the backend's Spring
		# HSTS config never fires (it only sees plain HTTP). Set it here at the
		# edge-facing layer instead; this covers both the static SPA responses
		# and the reverse-proxied /api/* responses. 1 year, matches the backend.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# connect-src covers the Cognito hosted-UI token exchange the SPA makes via
		# fetch/XHR after the OAuth redirect back from {$COGNITO_DOMAIN}.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://{$COGNITO_DOMAIN}; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
	}
}
