	<parameter name="INVOICE_BOOM_NUMBER_DESC" class="java.lang.String"/>
	<parameter name="INVOICE_BOOM_NUMBER_SQL" class="java.lang.String"/>
	<parameter name="INVOICE_TIMBER_MARK" forPrompting="false" class="java.util.List"/>
	<parameter name="INVOICE_TIMBER_MARK_DESC" class="java.lang.String"/>
	<parameter name="INVOICE_TIMBER_MARK_SQL" class="java.lang.String"/>
	<parameter name="INVOICE_WEIGH_SLIP" forPrompting="false" class="java.util.List"/>
	<parameter name="INVOICE_WEIGH_SLIP_DESC" class="java.lang.String"/>
	<parameter name="INVOICE_WEIGH_SLIP_SQL" class="java.lang.String"/>
	<parameter name="INVOICE_TYPE" forPrompting="false" class="java.util.List"/>
	<parameter name="FOB_POINT" forPrompting="false" class="java.util.List"/>
	<parameter name="MATURITY" forPrompting="false" class="java.util.List"/>
	<parameter name="SPECIES" forPrompting="false" class="java.util.List"/>
	<parameter name="SORT_CODE" forPrompting="false" class="java.util.List"/>
	<parameter name="GRADE" forPrompting="false" class="java.util.List"/>
	<parameter name="SUBMISSION_MONTH_YEAR" forPrompting="false" class="java.lang.String"/>
	<parameter name="SUBMISSION_STATUS" forPrompting="false" class="java.util.List"/>
	<parameter name="SUBMISSION_NUMBER" forPrompting="false" class="java.lang.String"/>
	<parameter name="ENTRY_USERID" forPrompting="false" class="java.lang.String"/>
	<parameter name="SUBMISSION_TYPE" forPrompting="false" class="java.util.List"/>
	<parameter name="APPROVAL_MONTH_YEAR" forPrompting="false" class="java.lang.String"/>
	<parameter name="APPROVED_BY" forPrompting="false" class="java.util.List"/>
	<parameter name="SELLER_NAME" forPrompting="false" class="java.lang.String"/>
	<parameter name="BUYER_NAME" forPrompting="false" class="java.lang.String"/>
	<parameter name="SELLER_NUMBER" forPrompting="false" class="java.util.List"/>
	<parameter name="BUYER_NUMBER" forPrompting="false" class="java.util.List"/>
	<parameter name="SELLER_CLIENT_LOCN_CODE" forPrompting="false" class="java.util.List"/>
	<parameter name="BUYER_CLIENT_LOCN_CODE" forPrompting="false" class="java.util.List"/>
	<parameter name="REPORT_NAME" forPrompting="false" class="java.lang.String"/>
	<query language="sql"><![CDATA[select (to_char(sub.entry_timestamp, 'yyyy-mm')) Submission_YYYYMM,
       (to_char(i.approved_date, 'yyyy-mm')) Approval_YYYYMM,
       (i.seller_client_number) seller_client_number,
       (i.seller_client_locn_code) seller_location_code,
       (i.buyer_client_number) buyer_client_number,
       (i.buyer_client_locn_code) buyer_location_code,
       (i.client_invoice_no) client_invoice_no,
       (i.client_invoice_date) client_invoice_date,
       (i.log_sale_entry_status_code) log_sale_entry_status_code,
       (invs.description) log_sale_entry_status_desc,
       (sub.submission_id) submission_id,
       (sub.csp_submission_status_code) csp_submission_status_code,
       (ss.description) Submission_Status_Desc,
       sub_type.submission_type submission_type_desc,
       (i.csp_invoice_type_code) csp_invoice_type_code,
       (it.description) invoice_Type_Desc,
       (i.client_primary_sort_code) primary_sort_code,
       (id.log_sale_sort_code) log_sale_sort_code,
       (sc.description) sort_Code_Desc,
       (i.log_sale_type_code) log_sale_type_code,
       (m.description) Maturity,
       case when ((i.buyer_client_number) is null) then '' else (bfc.client_name) END Buyer_Name,
       case when ((i.seller_client_number) is null) then '' else (sfc.client_name) END Seller_Name,
       case when ((i.buyer_client_number) is null) then '' else (bcl.client_locn_name) END Buyer_Loc_Name,
       case when ((i.seller_client_number) is null) then '' else (scl.client_locn_name) END Seller_Loc_Name,
       (i.approved_userid) approved_userid,
       (i.log_sale_fob_location) log_sale_fob_location,
       (sg.log_sale_species_code) log_sale_species_code,
       (s.description) Species_Desc,
       (sg.log_sale_grade_code) log_sale_grade_code,
       (g.description) grade_Desc,
       (id.pieces) pieces,
       (id.volume) volume,
       case
         when i.csp_invoice_type_code = 'ADJ' and id.price < 0 then
           (abs(id.price * id.volume) * -1)
         else
           (id.price * id.volume)
       end as amount,
       (totals.total_pieces) total_pieces,
       (totals.total_volume) total_volume,
       (case when i.log_sale_type_code = 'O' then 1 else 0 end) number_O_invoices,
       (case when i.log_sale_type_code = 'S' then 1 else 0 end) number_S_invoices,
       (case when i.log_sale_type_code = 'M' then 1 else 0 end) number_M_invoices,
       (totals.total_amount) total_amount,
       case when ((id.converted_price) is null or (id.converted_price) = 0.0) Then (id.price) else 0 END Flat_Price,
       case when ((id.converted_price) is null or (id.converted_price) = 0.0) then 0 else (id.price) end Spread_Price,
       (id.converted_price) price,
       case when ((id.converted_price) is null or (id.converted_price) = 0.0) then 0 else (id.price / id.converted_price) end conversion_factor,
       rep_adj.rep_adj_inv_id replaces_adjusts,
       boom_nums.boom_num_src boom_numbers,
       tmbr_mks.tmbr_mks_src timber_marks,
       weigh_sl.weigh_slips_src weigh_slips,
       (i.reviewer_notes) reviewer_notes,
       (i.submitter_notes) submitter_notes,
       (i.entry_userid) entry_userid
  from coastal_log_sale i,
       csp_submission sub,
       coastal_log_sale_detail id,
       csp_submission_status_code ss,
       log_sale_entry_status_code invs,
       csp_invoice_type_code it,
       log_sale_sort_code sc,
       log_sale_type_code m,
       client_location scl,
       forest_client sfc,
       client_location bcl,
       forest_client bfc,
       csp_species_grade_xref sg,
       LOG_SALE_GRADE_CODE g,
       LOG_SALE_SPECIES_CODE s,
       (select (i.coastal_log_sale_id) coastal_log_sale_id,
               sum(id.volume) total_volume,
               sum(id.pieces) total_pieces,
               sum(
                 case
                   when i.csp_invoice_type_code = 'ADJ' and id.price < 0 then
                     (abs(id.price * id.volume) * -1)
                   else
                     (id.price * id.volume)
                 end
               ) as total_amount
        from coastal_log_sale i,
             csp_submission sub,
             coastal_log_sale_detail id,
             csp_species_grade_xref sg
        where i.csp_submission_id = sub.csp_submission_id(+)
              and i.coastal_log_sale_id = id.coastal_log_sale_id(+)
              and id.csp_species_grade_xref_id = sg.csp_species_grade_xref_id(+)
              and ((TO_CHAR(i.client_invoice_date, 'yyyyMMdd') >= $P{INVOICE_DATE_FROM}) or ($P{INVOICE_DATE_FROM} is null))
              and ((TO_CHAR(i.client_invoice_date, 'yyyyMMdd') <= $P{INVOICE_DATE_TO}) or ($P{INVOICE_DATE_TO} is null))
              and $X{IN, i.client_invoice_no, INVOICE_NUMBER}
              and ((i.client_invoice_no >= $P{INVOICE_NUMBER_FROM}) or ($P{INVOICE_NUMBER_FROM} is null))
              and ((i.client_invoice_no <= $P{INVOICE_NUMBER_TO}) or ($P{INVOICE_NUMBER_TO} is null))
              and $X{IN, i.seller_client_number, SELLER_NUMBER}
              and $X{IN, i.seller_client_locn_code, SELLER_CLIENT_LOCN_CODE}
              and $X{IN, i.buyer_client_number, BUYER_NUMBER}
              and $X{IN, i.buyer_client_locn_code, BUYER_CLIENT_LOCN_CODE}
              and $X{IN, i.log_sale_entry_status_code, INVOICE_STATUS}
              and $X{IN, i.log_sale_type_code, MATURITY}
              and ((TO_CHAR(i.approved_date, 'yyyyMM') = $P{APPROVAL_MONTH_YEAR}) or ($P{APPROVAL_MONTH_YEAR} is null))
              and ((TO_CHAR(sub.entry_timestamp, 'yyyyMM') = $P{SUBMISSION_MONTH_YEAR}) or ($P{SUBMISSION_MONTH_YEAR} is null))
              and $X{IN, i.approved_userid, APPROVED_BY}
              and $X{IN, sub.csp_submission_status_code, SUBMISSION_STATUS}
              and ((sub.submission_id = $P{SUBMISSION_NUMBER}) or ($P{SUBMISSION_NUMBER} is null))
              and ($X{IN, id.log_sale_sort_code, SORT_CODE} or id.log_sale_sort_code is null)
              and ($X{IN, sg.log_sale_species_code, SPECIES} or sg.log_sale_species_code is null)
              and ($X{IN, sg.log_sale_grade_code, GRADE} or sg.log_sale_grade_code is null)
              and $X{IN, i.log_sale_fob_location, FOB_POINT}
        group by i.coastal_log_sale_id) totals,
       (select listagg(rltd.client_invoice_no, ',') within group(order by client_invoice_no) rep_adj_inv_id, rltd.coastal_log_sale_id
         from (select rls.client_invoice_no, rl.coastal_log_sale_id from coastal_log_sale_rltd_invc rl
               left join coastal_log_sale rls on rl.related_coastal_log_sale_id = rls.coastal_log_sale_id) rltd
         group by rltd.coastal_log_sale_id) rep_adj,
       (select listagg(src_doc_ref.source_document_reference, ',') within group(order by source_document_reference) boom_num_src, src_doc_ref.coastal_log_sale_id
         from (select src.source_document_reference, src.coastal_log_sale_id from coastal_log_sale_log_source src 
               where src.log_source_code = 'BOOM') src_doc_ref
         group by src_doc_ref.coastal_log_sale_id) boom_nums,
       (select listagg(src_doc_ref.source_document_reference, ',') within group(order by source_document_reference) tmbr_mks_src, src_doc_ref.coastal_log_sale_id
         from (select src.source_document_reference, src.coastal_log_sale_id from coastal_log_sale_log_source src 
               where src.log_source_code = 'MARK') src_doc_ref
         group by src_doc_ref.coastal_log_sale_id) tmbr_mks,
       (select listagg(src_doc_ref.source_document_reference, ',') within group(order by source_document_reference) weigh_slips_src, src_doc_ref.coastal_log_sale_id
         from (select src.source_document_reference, src.coastal_log_sale_id from coastal_log_sale_log_source src 
               where src.log_source_code = 'WEIGH') src_doc_ref
         group by src_doc_ref.coastal_log_sale_id) weigh_sl,
       (select sub1.csp_submission_id,
         case 
           when sub1.submission_id is null then 'Manual'
           else 'Electronic'
          end submission_type
        from csp_submission sub1) sub_type
 where i.csp_submission_id = sub.csp_submission_id(+)
   and i.coastal_log_sale_id = id.coastal_log_sale_id(+)
   and i.csp_invoice_type_code = it.csp_invoice_type_code(+)
   and i.log_sale_type_code = m.log_sale_type_code(+)
   and id.log_sale_sort_code = sc.log_sale_sort_code(+)
   and sub.csp_submission_status_code = ss.csp_submission_status_code(+)
   and id.csp_species_grade_xref_id = sg.csp_species_grade_xref_id(+)
   and sg.log_sale_species_code = s.log_sale_species_code(+)
   and sg.log_sale_grade_code = g.log_sale_grade_code(+)
   and i.log_sale_entry_status_code = invs.log_sale_entry_status_code(+)
   and i.seller_client_number = scl.client_number(+)
   and i.seller_client_locn_code = scl.client_locn_code(+)
   and i.buyer_client_number = bcl.client_number(+)
   and i.buyer_client_locn_code = bcl.client_locn_code(+)
   and scl.client_number = sfc.client_number(+)
   and bcl.client_number = bfc.client_number(+)
   and i.coastal_log_sale_id = totals.coastal_log_sale_id(+)
   and i.coastal_log_sale_id = rep_adj.coastal_log_sale_id(+)
   and i.coastal_log_sale_id = boom_nums.coastal_log_sale_id(+)
   and i.coastal_log_sale_id = tmbr_mks.coastal_log_sale_id(+)
   and i.coastal_log_sale_id = weigh_sl.coastal_log_sale_id(+)
   and i.csp_submission_id = sub_type.csp_submission_id(+)
   and ((TO_CHAR(i.client_invoice_date, 'yyyyMMdd') >= $P{INVOICE_DATE_FROM}) or ($P{INVOICE_DATE_FROM} is null))
   and ((TO_CHAR(i.client_invoice_date, 'yyyyMMdd') <= $P{INVOICE_DATE_TO}) or ($P{INVOICE_DATE_TO} is null))
   and $X{IN, i.client_invoice_no, INVOICE_NUMBER}
   and ((i.client_invoice_no >= $P{INVOICE_NUMBER_FROM}) or ($P{INVOICE_NUMBER_FROM} is null))
   and ((i.client_invoice_no <= $P{INVOICE_NUMBER_TO}) or ($P{INVOICE_NUMBER_TO} is null))
   and ($P!{INVOICE_REPLACES_ADJUSTS_SQL})
   and ($P!{INVOICE_BOOM_NUMBER_SQL})
   and ($P!{INVOICE_TIMBER_MARK_SQL})
   and ($P!{INVOICE_WEIGH_SLIP_SQL})
   and $X{IN, i.csp_invoice_type_code, INVOICE_TYPE}
   and $X{IN, i.seller_client_number, SELLER_NUMBER}
   and $X{IN, i.seller_client_locn_code, SELLER_CLIENT_LOCN_CODE}
   and $X{IN, i.buyer_client_number, BUYER_NUMBER}
   and $X{IN, i.buyer_client_locn_code, BUYER_CLIENT_LOCN_CODE}
   and $X{IN, i.log_sale_entry_status_code, INVOICE_STATUS}
   and $X{IN, i.log_sale_type_code, MATURITY}
   and ((TO_CHAR(i.approved_date, 'yyyyMM') = $P{APPROVAL_MONTH_YEAR}) or ($P{APPROVAL_MONTH_YEAR} is null))
   and ((TO_CHAR(sub.entry_timestamp, 'yyyyMM') = $P{SUBMISSION_MONTH_YEAR}) or ($P{SUBMISSION_MONTH_YEAR} is null))
   and $X{IN, i.approved_userid, APPROVED_BY}
   and ($X{IN, sub.csp_submission_status_code, SUBMISSION_STATUS} or sub.csp_submission_status_code is null)
   and ((sub.submission_id = $P{SUBMISSION_NUMBER}) or ($P{SUBMISSION_NUMBER} is null))
   and ($X{IN, sub_type.submission_type, SUBMISSION_TYPE} or sub_type.submission_type is null)
   and ($X{IN, id.log_sale_sort_code, SORT_CODE} or id.log_sale_sort_code is null)
   and ($X{IN, sg.log_sale_species_code, SPECIES} or sg.log_sale_species_code is null)
   and ($X{IN, sg.log_sale_grade_code, GRADE} or sg.log_sale_grade_code is null)
   and $X{IN, i.log_sale_fob_location, FOB_POINT}
   and ((i.ENTRY_USERID = $P{ENTRY_USERID}) or ($P{ENTRY_USERID} is null))
 order by id.csp_species_grade_xref_id,
          id.log_sale_sort_code,
          i.log_sale_type_code]]></query>
